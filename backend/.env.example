# Server
PORT=5000

# MySQL (local on VPS)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=engagement
DB_USER=root
DB_PASSWORD=

# JWT secret for admin auth (change to a long random string)
JWT_SECRET=change_this_to_a_long_random_secret_string

# Admin login credentials (seeded on first run)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123

# Public base URL of the API (used to build image URLs). On VPS set to your domain.
PUBLIC_BASE_URL=http://localhost:5000

# OTP mode: "mock" prints OTP to console / returns in dev. Swap later for a real SMS gateway.
OTP_MODE=mock
